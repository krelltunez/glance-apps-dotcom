---
import BaseLayout from '../layouts/BaseLayout.astro';
import AppCard from '../components/AppCard.astro';

const apps = [
  {
    name: 'dayGLANCE',
    prefix: 'day',
    suffix: 'GLANCE',
    tagline: 'See your day clearly.',
    description:
      "A calm daily planner for morning intentions, quiet notes, and evening reflection. Everything you need for a focused day. Nothing you don't.",
    href: '/apps/dayglance',
    status: 'live',
    accentColor: '#fe8b00',
    icon: '/icons/dayglance-icon.png',
  },
  {
    name: 'lifeGLANCE',
    prefix: 'life',
    suffix: 'GLANCE',
    tagline: 'Your life, at a glance.',
    description:
      'A personal dashboard for the things that matter most. Goals, habits, milestones. Curated, not cluttered. Step back and see the shape of your life.',
    href: '/apps/lifeglance',
    status: 'live',
    accentColor: '#7b70db',
    icon: '/icons/lifeglance-icon.png',
  },
  {
    name: 'lastGLANCE',
    prefix: 'last',
    suffix: 'GLANCE',
    tagline: 'When did you last...?',
    description:
      "A calm tracker for the recurring upkeep in your life. Cleaning, car maintenance, pet care, health care, finances. The things you don't want to forget but don't want to nag you.",
    href: '/apps/lastglance',
    status: 'live',
    accentColor: '#3DDB84',
    icon: '/icons/lastglance-icon.png',
  },
] as const;
---

<BaseLayout
  title="GLANCE Apps"
  description="Thoughtful apps for everyday clarity. GLANCE Apps makes calm, focused tools for Android, iOS, macOS, Windows, and Linux."
>
  <!-- Hero -->
  <section class="max-w-5xl mx-auto px-6 pt-24 pb-20 md:pt-32 md:pb-28">
    <div class="max-w-2xl">
      <p class="text-xs font-sans font-semibold uppercase tracking-widest text-glance-accent mb-6">
        A small indie studio
      </p>
      <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl font-semibold text-glance-text leading-[1.1] mb-6">
        Thoughtful apps for everyday clarity.
      </h1>
      <p class="text-lg md:text-xl text-glance-muted font-serif leading-relaxed max-w-xl">
        We make calm, focused apps for Android, iOS, macOS, Windows, and Linux that give you
        room to breathe, and room to think.
      </p>
    </div>
  </section>

  <!-- Apps -->
  <section class="section-rule">
    <div class="max-w-5xl mx-auto px-6 py-16 md:py-20">
      <h2 class="text-xs font-sans font-semibold uppercase tracking-widest text-glance-dim mb-10">
        Our Apps
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {apps.map((app) => (
          <AppCard {...app} />
        ))}
      </div>
    </div>
  </section>

  <!-- GLANCEintents -->
  <section class="section-rule">
    <div class="max-w-5xl mx-auto px-6 py-16 md:py-20">
      <img
        src="/glanceintents-pill-hero-dark.svg"
        alt="GLANCEintents"
        width="260"
        height="56"
        class="mb-8"
      />
      <div class="max-w-xl">
        <h2 class="font-serif text-2xl md:text-3xl font-semibold text-glance-text leading-snug mb-6">
          One family. Many surfaces.
        </h2>
        <div class="space-y-4 text-glance-muted font-serif text-lg leading-relaxed">
          <p>
            GLANCEintents is the protocol that connects the GLANCE family. For example, you can
            flag a chore in lastGLANCE and send it to your dayGLANCE timeline. Then, when you
            complete it in dayGLANCE, the app sends a notification to lastGLANCE and the log is
            updated. Optional end-to-end encryption keyed to your sync passphrase. No GLANCE Apps
            account. No GLANCE Apps servers. Off by default.
          </p>
          <p>
            The protocol is open and documented. Build your own integrations.{' '}
            <a
              href="https://github.com/krelltunez/GLANCEintents"
              target="_blank"
              rel="noopener noreferrer"
              class="text-glance-accent link-underline"
            >Spec on GitHub →</a>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Philosophy -->
  <section class="section-rule">
    <div class="max-w-5xl mx-auto px-6 py-16 md:py-20">
      <div class="max-w-xl">
        <h2 class="text-xs font-sans font-semibold uppercase tracking-widest text-glance-dim mb-8">
          Our Philosophy
        </h2>
        <div class="space-y-5 text-glance-muted font-serif text-lg leading-relaxed">
          <p>
            Every GLANCE app is built around one question: <em class="text-glance-text not-italic">does this deserve your attention?</em>
          </p>
          <p>
            We believe the best tools disappear into your routine. They don't demand
            your time. They give it back to you. We build with restraint, ship
            deliberately, and iterate based on what users actually need.
          </p>
          <p>
            One developer. Real care. Android · iOS · macOS · Windows · Linux.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
