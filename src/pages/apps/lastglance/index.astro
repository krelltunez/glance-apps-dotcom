---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="lastGLANCE"
  description="lastGLANCE is a calm tracker for the recurring upkeep in your life. Cleaning, car maintenance, pet care, health care, finances. Launching soon."
  ogImage="/og/lastglance.svg"
>
  <article class="max-w-5xl mx-auto px-6 py-20 md:py-28">
    <!-- Breadcrumb -->
    <nav class="mb-10 font-sans text-sm text-glance-dim" aria-label="Breadcrumb">
      <a href="/" class="hover:text-glance-muted transition-colors">GLANCE Apps</a>
      <span class="mx-2">/</span>
      <span class="text-glance-muted">lastGLANCE</span>
    </nav>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-start">
      <!-- Left column -->
      <div>
        <div class="mb-4 inline-flex items-center gap-2">
          <span class="text-xs font-sans font-semibold uppercase tracking-widest text-glance-dim border border-glance-border-dim rounded-full px-3 py-1 bg-glance-surface">
            Coming soon
          </span>
        </div>

        <h1 class="font-serif text-5xl md:text-6xl font-semibold leading-none mb-4">
          <span class="text-glance-muted font-medium">last</span><span style="color: #3DDB84;" class="tracking-wider font-bold">GLANCE</span>
        </h1>
        <p class="text-xl text-glance-muted font-serif italic mb-8">
          When did you last...?
        </p>

        <div class="space-y-5 text-glance-muted font-serif text-lg leading-relaxed mb-6">
          <p>
            lastGLANCE is a calm tracker for the recurring upkeep in your life.
            Cleaning, car maintenance, pet care, health care, finances. The things
            you don't want to forget but don't want to nag you. Built with the same
            care as the rest of the GLANCE family.
          </p>
          <p>
            Launching soon.
          </p>
        </div>

        <!-- Platforms -->
        <div class="bg-glance-surface border border-glance-border-dim rounded-xl p-6">
          <h2 class="text-xs font-sans font-semibold uppercase tracking-widest text-glance-dim mb-3">
            Platforms
          </h2>
          <p class="font-sans text-sm text-glance-muted">Web first. More to follow.</p>
        </div>
      </div>

      <!-- Right column -->
      <div class="space-y-6">
        <!-- What it does -->
        <div class="bg-glance-surface border border-glance-border-dim rounded-xl p-6">
          <h2 class="text-xs font-sans font-semibold uppercase tracking-widest text-glance-dim mb-5">
            What it does
          </h2>
          <p class="text-xs font-sans font-semibold uppercase tracking-widest text-glance-dim mb-3">Core</p>
          <ul class="space-y-4 font-sans text-sm text-glance-muted mb-5">
            <li class="flex gap-3">
              <span style="color: #3DDB84;" class="mt-0.5 shrink-0">◆</span>
              <span><strong class="text-glance-text font-medium">Last-done tracking</strong>: Track when you last did something. See everything at a glance, color-coded by how long it's been. Drill in for per-item history, custom completion dates, and notes.</span>
            </li>
            <li class="flex gap-3">
              <span style="color: #3DDB84;" class="mt-0.5 shrink-0">◆</span>
              <span><strong class="text-glance-text font-medium">Flexible organization</strong>: Group items into categories and subcategories. Make a category per pet, per room, per car. Whatever fits your life.</span>
            </li>
            <li class="flex gap-3">
              <span style="color: #3DDB84;" class="mt-0.5 shrink-0">◆</span>
              <span><strong class="text-glance-text font-medium">One-tap done</strong>: Mark something done with a single click. No forms, no friction. The card returns to fresh and the timer resets.</span>
            </li>
            <li class="flex gap-3">
              <span style="color: #3DDB84;" class="mt-0.5 shrink-0">◆</span>
              <span><strong class="text-glance-text font-medium">Activity heatmap</strong>: A visual history of when you actually did things, across everything you track.</span>
            </li>
          </ul>
          <div class="border-t border-glance-border pt-5">
            <p class="text-xs font-sans font-semibold uppercase tracking-widest text-glance-dim mb-3">Optional</p>
            <p class="font-sans text-sm text-glance-muted leading-relaxed">
              Cadence targets and reminders for things you don't want to forget. All off by default.
            </p>
          </div>
        </div>

        <!-- Stay in the loop -->
        <div class="bg-glance-surface border border-glance-border-dim rounded-xl p-6">
          <h2 class="text-xs font-sans font-semibold uppercase tracking-widest text-glance-dim mb-4">
            Stay in the loop
          </h2>
          <p class="font-sans text-sm text-glance-muted leading-relaxed">
            Email <a href="mailto:hello@glance-apps.com?subject=lastGLANCE%20interest" class="last-accent-link">hello@glance-apps.com</a> to be notified when lastGLANCE launches.
          </p>
        </div>
      </div>
    </div>

    <div class="mt-16 pt-10 section-rule">
      <p class="font-sans text-sm text-glance-dim">
        In the meantime, explore our existing apps:
        <a href="/apps/dayglance" class="last-accent-link ml-1">dayGLANCE</a>
        <span class="mx-2 text-glance-border">·</span>
        <a href="/apps/lifeglance" class="last-accent-link">lifeGLANCE</a>
      </p>
    </div>
  </article>
</BaseLayout>

<style>
  .last-accent-link {
    color: #3DDB84;
    text-decoration: underline;
    text-decoration-color: #3DDB8440;
    text-underline-offset: 3px;
    transition: color 0.15s, text-decoration-color 0.15s;
  }
  .last-accent-link:hover {
    text-decoration-color: #3DDB84;
  }
</style>
