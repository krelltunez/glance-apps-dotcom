---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="lastGLANCE"
  description="lastGLANCE is the next app from GLANCE Apps. Coming soon."
  ogImage="/og/lastglance.svg"
>
  <article class="max-w-5xl mx-auto px-6 py-20 md:py-28">
    <!-- Breadcrumb -->
    <nav class="mb-10 font-sans text-sm text-glance-dim" aria-label="Breadcrumb">
      <a href="/" class="hover:text-glance-muted transition-colors">GLANCE Apps</a>
      <span class="mx-2">/</span>
      <span class="text-glance-muted">lastGLANCE</span>
    </nav>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-start">
      <!-- Left column -->
      <div>
        <div class="mb-4 inline-flex items-center gap-2">
          <span class="text-xs font-sans font-semibold uppercase tracking-widest text-glance-dim border border-glance-border-dim rounded-full px-3 py-1 bg-glance-surface">
            Coming soon
          </span>
        </div>

        <h1 class="font-serif text-5xl md:text-6xl font-semibold leading-none mb-4">
          <span class="text-glance-muted font-medium">last</span><span style="color: #3DDB84;" class="tracking-wider font-bold">GLANCE</span>
        </h1>
        <p class="text-xl text-glance-muted font-serif italic mb-8">
          When did you last...?
        </p>

        <div class="space-y-5 text-glance-muted font-serif text-lg leading-relaxed">
          <p>
            lastGLANCE is a calm tracker for the recurring upkeep in your life.
            Cleaning, car maintenance, pet care, health care, finances. The things
            you don't want to forget but don't want to nag you. Built with the same
            care as the rest of the GLANCE family.
          </p>
          <p>
            Launching soon.
          </p>
        </div>
      </div>

      <!-- Right column -->
      <div class="space-y-6">
        <div class="bg-glance-surface border border-glance-border-dim rounded-xl p-6">
          <h2 class="text-xs font-sans font-semibold uppercase tracking-widest text-glance-dim mb-4">
            Stay in the loop
          </h2>
          <p class="font-sans text-sm text-glance-muted leading-relaxed mb-4">
            To be notified when lastGLANCE launches, reach out and we'll add you
            to the list.
          </p>
          <a
            href="mailto:hello@glance-apps.com?subject=lastGLANCE%20interest"
            class="font-sans text-sm last-accent-link"
          >
            Contact us to stay informed →
          </a>
        </div>
      </div>
    </div>

    <div class="mt-16 pt-10 section-rule">
      <p class="font-sans text-sm text-glance-dim">
        In the meantime, explore our existing apps:
        <a href="/apps/dayglance" class="last-accent-link ml-1">dayGLANCE</a>
        <span class="mx-2 text-glance-border">·</span>
        <a href="/apps/lifeglance" class="last-accent-link">lifeGLANCE</a>
      </p>
    </div>
  </article>
</BaseLayout>

<style>
  .last-accent-link {
    color: #3DDB84;
    text-decoration: underline;
    text-decoration-color: #3DDB8440;
    text-underline-offset: 3px;
    transition: color 0.15s, text-decoration-color 0.15s;
  }
  .last-accent-link:hover {
    text-decoration-color: #3DDB84;
  }
</style>
