---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import DownloadsList from '../../../components/DownloadsList.astro';
---

<BaseLayout
  title="lastGLANCE Downloads"
  description="Open lastGLANCE in any modern browser. No install required."
>
  <article class="max-w-2xl mx-auto px-6 py-20 md:py-28">
    <!-- Breadcrumb -->
    <nav class="mb-10 font-sans text-sm text-glance-dim" aria-label="Breadcrumb">
      <a href="/" class="hover:text-glance-muted transition-colors">GLANCE Apps</a>
      <span class="mx-2">/</span>
      <a href="/apps/lastglance" class="hover:text-glance-muted transition-colors">lastGLANCE</a>
      <span class="mx-2">/</span>
      <span class="text-glance-muted">Downloads</span>
    </nav>

    <h1 class="font-serif text-4xl md:text-5xl font-semibold leading-none mb-4">
      <span class="text-glance-muted font-medium">last</span><span style="color: #3DDB84;" class="tracking-wider font-bold">GLANCE</span>
    </h1>
    <p class="text-xl text-glance-muted font-serif italic mb-2">When did you last...?</p>
    <p class="font-sans text-sm text-glance-dim mb-10">
      Currently available on the web. Android, iOS, macOS, Windows, and Linux coming soon.
    </p>

    <!-- Desktop (fetched from GitHub) -->
    <DownloadsList repo="krelltunez/lastGLANCE" accentColor="#3DDB84" />

    <!-- Web -->
    <div class="mt-10 pt-10 section-rule">
      <h2 class="text-xs font-sans font-semibold uppercase tracking-widest text-glance-dim mb-6">
        Web
      </h2>
      <p class="font-sans text-sm text-glance-muted mb-3">
        No install required. Open lastGLANCE in any modern browser.
      </p>
      <a
        href="https://lastglance.app"
        target="_blank"
        rel="noopener noreferrer"
        class="font-sans text-sm last-accent-link"
      >
        Open lastglance.app →
      </a>
      <p class="font-sans text-sm text-glance-muted mt-3">
        Or self-host: see <a href="https://github.com/krelltunez/lastGLANCE#readme" target="_blank" rel="noopener noreferrer" class="last-accent-link">GitHub</a> for setup instructions.
      </p>
    </div>
  </article>
</BaseLayout>

<style>
  .last-accent-link {
    color: #3DDB84;
    text-decoration: underline;
    text-decoration-color: #3DDB8440;
    text-underline-offset: 3px;
    transition: color 0.15s, text-decoration-color 0.15s;
  }
  .last-accent-link:hover {
    text-decoration-color: #3DDB84;
  }
</style>
