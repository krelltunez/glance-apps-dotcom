---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  lastUpdated?: string;
}

const { title, description, lastUpdated } = Astro.props;
---

<BaseLayout title={title} description={description} ogType="article">
  <article class="max-w-2xl mx-auto px-6 py-20 md:py-28">
    <header class="mb-12">
      <h1 class="font-serif text-3xl md:text-4xl font-semibold text-glance-text leading-tight mb-4">
        {title}
      </h1>
      {lastUpdated && (
        <p class="text-sm text-glance-muted font-sans">
          Last updated {lastUpdated}
        </p>
      )}
    </header>
    <div class="prose prose-glance prose-lg leading-relaxed">
      <slot />
    </div>
  </article>
</BaseLayout>
