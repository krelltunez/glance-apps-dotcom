---
const year = new Date().getFullYear();

const footerLinks = [
  {
    group: 'Apps',
    links: [
      { href: '/apps/dayglance', label: 'dayGLANCE' },
      { href: '/apps/lifeglance', label: 'lifeGLANCE' },
      { href: '/apps/lastglance', label: 'lastGLANCE' },
    ],
  },
  {
    group: 'Company',
    links: [
      { href: '/about', label: 'About' },
      { href: '/contact', label: 'Contact' },
    ],
  },
  {
    group: 'Legal',
    links: [
      { href: '/privacy', label: 'Privacy Policy' },
      { href: '/eula', label: 'Terms of Use' },
    ],
  },
];

const sourceLinks = [
  { href: 'https://github.com/krelltunez/dayGLANCE', label: 'dayGLANCE' },
  { href: 'https://github.com/krelltunez/lifeGLANCE', label: 'lifeGLANCE' },
];
---

<footer class="section-rule mt-auto">
  <div class="max-w-5xl mx-auto px-6 py-14">
    <div class="grid grid-cols-2 md:grid-cols-5 gap-10 mb-12">
      <div class="col-span-2 md:col-span-1">
        <a href="/" class="wordmark text-glance-text hover:text-glance-accent transition-colors duration-150 text-lg">
          <span class="wordmark-glance">GLANCE</span><span class="text-glance-muted font-light"> Apps</span>
        </a>
        <p class="mt-3 text-sm text-glance-dim font-sans leading-relaxed">
          Thoughtful apps<br />for everyday clarity.
        </p>
      </div>

      {footerLinks.slice(0, 1).map(({ group, links }) => (
        <div>
          <h3 class="text-xs font-sans font-semibold uppercase tracking-widest text-glance-dim mb-4">
            {group}
          </h3>
          <ul class="space-y-2.5">
            {links.map(({ href, label }) => (
              <li>
                <a
                  href={href}
                  class="text-sm font-sans text-glance-muted hover:text-glance-text transition-colors duration-150"
                >
                  {label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}

      <div>
        <h3 class="text-xs font-sans font-semibold uppercase tracking-widest text-glance-dim mb-4">
          Source
        </h3>
        <ul class="space-y-2.5">
          {sourceLinks.map(({ href, label }) => (
            <li>
              <a
                href={href}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 text-sm font-sans text-glance-muted hover:text-glance-text transition-colors duration-150"
              >
                <svg viewBox="0 0 24 24" width="13" height="13" fill="currentColor" aria-hidden="true" class="shrink-0 opacity-60">
                  <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
                </svg>
                {label}
              </a>
            </li>
          ))}
          <li class="text-sm font-sans text-glance-dim">
            lastGLANCE <span class="text-xs opacity-60">soon</span>
          </li>
        </ul>
      </div>

      {footerLinks.slice(1).map(({ group, links }) => (
        <div>
          <h3 class="text-xs font-sans font-semibold uppercase tracking-widest text-glance-dim mb-4">
            {group}
          </h3>
          <ul class="space-y-2.5">
            {links.map(({ href, label }) => (
              <li>
                <a
                  href={href}
                  class="text-sm font-sans text-glance-muted hover:text-glance-text transition-colors duration-150"
                >
                  {label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="section-rule pt-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3">
      <p class="text-xs font-sans text-glance-dim">
        &copy; {year} GLANCE Apps. All rights reserved.
      </p>
      <p class="text-xs font-sans text-glance-dim">
        Web · Android · macOS · Windows · Linux · iOS (soon)
      </p>
    </div>
  </div>
</footer>
